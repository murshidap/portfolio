---
import { AdminApp } from "@/components/admin/AdminApp";
import { fetchPortfolioContent } from "@/lib/server/content";
import { getAdminUserFromRequest } from "@/lib/server/auth";
import BaseLayout from "@/layouts/BaseLayout.astro";

export const prerender = false;

const user = await getAdminUserFromRequest(Astro.request);
const initialContent = user ? await fetchPortfolioContent(true) : null;
---

<BaseLayout title="Admin | Murshida P.">
  <main class="min-h-screen bg-[#050818] bg-hero-grid text-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_10%,rgba(88,105,255,0.22),transparent_24%)]"></div>
    <div class="relative z-10">
      <AdminApp client:load authenticated={Boolean(user)} initialContent={initialContent} />
    </div>
  </main>
</BaseLayout>
